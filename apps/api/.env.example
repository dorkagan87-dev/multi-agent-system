# Database
DATABASE_URL="postgresql://agenthub:agenthub_pass@localhost:5432/agenthub"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET="change_me_access_secret_32chars_min"
JWT_REFRESH_SECRET="change_me_refresh_secret_32chars_min"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Encryption key for provider API keys (32 bytes hex = openssl rand -hex 32)
ENCRYPTION_KEY="change_me_32_byte_hex_key_here_ok"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Worker concurrency
WORKER_CONCURRENCY=5

# CORS
CORS_ORIGIN="http://localhost:3000"

# Sentry error reporting (optional — skip to disable)
# SENTRY_DSN="https://<key>@o<org>.ingest.sentry.io/<project>"

# SMTP — all optional; if absent, reset links are logged to console (dev mode)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASS="password"
# SMTP_FROM="AgentHub <no-reply@agenthub.ai>"
