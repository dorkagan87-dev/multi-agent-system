NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_nextauth_secret_min_32_chars

# Sentry error reporting (optional — skip to disable)
# Client-side DSN (exposed to browser — safe, read-only key)
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@o<org>.ingest.sentry.io/<project>"
# Server-side DSN (same value; kept separate so it can be rotated independently)
# SENTRY_DSN="https://<key>@o<org>.ingest.sentry.io/<project>"
# Sourcemap upload — only needed for production builds with source map upload
# SENTRY_AUTH_TOKEN="sntrys_..."
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
